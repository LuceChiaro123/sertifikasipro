# Default proyek: SQLite (zero-config, langsung jalan). Salin file ini jadi .env
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# Alternatif PostgreSQL (untuk produksi):
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sertifikasipro
SECRET_KEY=sertifikasipro-dev-secret-key-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=email@gmail.com
SMTP_PASSWORD=app-password
SMTP_FROM=noreply@sertifikasipro.id

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
APP_ENV=development
